SECRET_KEY=change-this-to-a-random-32-char-string
DEBUG=false
ALLOWED_HOSTS=*
DB_NAME=pischeduler.db
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
GPIO_MOCK=true
# MQTT (mosquitto: docker run -p 1883:1883 eclipse-mosquitto)
MQTT_ENABLED=true
MQTT_SUBSCRIBER_ENABLED=true
MQTT_ECHO_COMMANDS=true
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_STATUS=piorchestrator/device/status
MQTT_TOPIC_COMMANDS=piorchestrator/device/commands
MQTT_TOPIC_FEEDBACK=piorchestrator/device/feedback
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
